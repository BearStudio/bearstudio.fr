---
import { getTranslationUtilities } from '@/lib/site/get-translation-utilities';
import { getSkillsCollection } from '@/lib/skills';
import { breadcrumbEntries } from '@/components/breadcrumb/utils';
import Container from '@/components/container.astro';
import HeroContent from '@/components/hero/hero-content.astro';
import Hero from '@/components/hero/hero.astro';
import SEO from '@/components/seo/index.astro';
import { getAlternates } from '@/components/seo/utils';
import SkillCard from '@/components/skills/skill-card.astro';
import SkillsGrid from '@/components/skills/skills-grid.astro';
import MainLayout from '@/layouts/main-layout.astro';

const { t, locale } = getTranslationUtilities(Astro.currentLocale);

// [TODO]: See if we need to check properties for "published" skills
const allSkills = await getSkillsCollection({ locale });

const breadcrumb = breadcrumbEntries(locale)((entry) => [
  entry({
    path: '/fr/expertise',
    params: {},
    label: t('skills.root.breadcrumb'),
  }),
]);
---

<MainLayout>
  <SEO
    slot="seo"
    title={t('skills.root.metadata.title')}
    description={t('skills.root.metadata.description')}
    alternates={getAlternates('/fr/expertise', {})}
    breadcrumb={breadcrumb}
  />
  <Hero>
    <HeroContent
      breadcrumb={breadcrumb}
      title={t('skills.root.title')}
      description={t('skills.root.description')}
    />
  </Hero>
  <Container placement="overlapHero">
    <SkillsGrid>
      {allSkills.map((skill) => <SkillCard skill={skill} />)}
    </SkillsGrid>
  </Container>
</MainLayout>

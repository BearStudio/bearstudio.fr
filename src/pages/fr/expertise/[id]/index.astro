---
import { Image } from 'astro:assets';
import { render } from 'astro:content';

import { getLink } from '@/lib/link';
import { getTranslationUtilities } from '@/lib/site/get-translation-utilities';
import {
  getSkillsCollection,
  getSkillSlugInOtherLocale,
  type SkillWithComputed,
} from '@/lib/skills';
import { breadcrumbEntries } from '@/components/breadcrumb/utils';
import Container from '@/components/container.astro';
import HeroContent from '@/components/hero/hero-content.astro';
import Hero from '@/components/hero/hero.astro';
import Prose from '@/components/prose.astro';
import SEO from '@/components/seo/index.astro';
import type { Locale } from '@/i18n/utils';
import MainLayout from '@/layouts/main-layout.astro';

export async function generateStaticPaths(params: { locale: Locale }) {
  const skills = await getSkillsCollection({ locale: params.locale });

  return skills.map((skill) => ({
    params: { id: skill.data._computed.slug },
    props: { skill },
  }));
}

export async function getStaticPaths() {
  return generateStaticPaths({ locale: 'fr' });
}

type Props = {
  skill: SkillWithComputed;
};

const { skill } = Astro.props;
const { Content } = await render(skill);

const { t, locale } = getTranslationUtilities(Astro.currentLocale);

const breadcrumb = breadcrumbEntries(locale)((entry) => [
  entry({
    path: '/fr/expertise',
    params: {},
    label: t('skills.root.breadcrumb'),
  }),
  entry({
    path: '/fr/expertise/:id',
    params: {
      id: skill.data._computed.slug,
    },
    label: skill.data.name,
  }),
]);

const [slugFr, slugEn] = await Promise.all([
  getSkillSlugInOtherLocale(skill, 'fr'),
  getSkillSlugInOtherLocale(skill, 'en'),
]);
---

<MainLayout>
  <SEO
    slot="seo"
    title={skill.data.name}
    description={t('skills.root.metadata.description')}
    alternates={{
      fr: slugFr ? getLink('/fr/expertise/:id', 'fr', { id: slugFr }) : null,
      en: slugEn ? getLink('/fr/expertise/:id', 'en', { id: slugEn }) : null,
    }}
    breadcrumb={breadcrumb}
  />
  <Hero contentClassName="lg:pb-24">
    <HeroContent breadcrumb={breadcrumb}>
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-4">
          {
            !!skill.icon && (
              <Image
                src={skill.icon.data.image}
                alt={skill.data.name}
                width={64}
                height={64}
                class="size-16"
              />
            )
          }
          <h1
            class="font-heading text-accent text-4xl leading-tight font-bold text-balance md:text-5xl"
          >
            {skill.data.name}
          </h1>
        </div>
        <p class="max-w-[60ch] text-sm text-balance opacity-80">
          {skill.data.description}
        </p>
      </div>
    </HeroContent>
  </Hero>
  <Container>
    <Prose>
      <Content />
    </Prose>
  </Container>
</MainLayout>

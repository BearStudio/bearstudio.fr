---
import { cn } from '@/lib/tailwind/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div data-pswp-gallery class={cn(className)}>
  <slot />
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  import 'photoswipe/style.css';

  const wrapImage = (img: HTMLImageElement) => {
    const a = document.createElement('a');
    a.href = img.src;
    a.dataset.pswpWidth = String(img.naturalWidth);
    a.dataset.pswpHeight = String(img.naturalHeight);
    img.parentNode?.insertBefore(a, img);
    a.appendChild(img);
  };

  document
    .querySelectorAll<HTMLImageElement>('[data-pswp-gallery] img')
    .forEach((img) => {
      if (img.closest('a')) return;

      if (img.complete && img.naturalWidth > 0) {
        wrapImage(img);
      } else {
        img.addEventListener('load', () => wrapImage(img), { once: true });
      }

      new PhotoSwipeLightbox({
        gallery: img.parentElement!,
        children: 'a',
        pswpModule: () => import('photoswipe'),
      }).init();
    });
</script>

<style>
  [data-pswp-gallery] :global(img) {
    cursor: zoom-in;
  }
</style>

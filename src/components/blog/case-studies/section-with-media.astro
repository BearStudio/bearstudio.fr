---
import { cn } from '@/lib/tailwind/utils';

interface Props {
  /**
   * Position of the media slot relative to the content.
   * "start" = media on the left, "end" = media on the right.
   * @default "end"
   */
  mediaPosition?: 'start' | 'end';
  /**
   * When true, the media bleeds slightly past the container edge toward
   * the nearest viewport side.
   */
  bleedMedia?: boolean;
  /**
   * Base width of the media column (before bleed is added).
   * @default "450px"
   */
  mediaWidth?: string | undefined;
  class?: string | undefined;
}

const {
  mediaPosition = 'end',
  bleedMedia = false,
  mediaWidth = '450px',
  class: className,
} = Astro.props;

// Fixed bleed: pushes media past the container padding edge
const bleedAmount = '3rem';
const bleedStyle = bleedMedia
  ? mediaPosition === 'start'
    ? `margin-left: -${bleedAmount}; width: calc(${mediaWidth} + ${bleedAmount});`
    : `margin-right: -${bleedAmount}; width: calc(${mediaWidth} + ${bleedAmount});`
  : undefined;
---

<div
  class={cn(
    'not-prose flex flex-col items-center gap-4 py-19 lg:flex-row',
    className
  )}
>
  <div
    class={cn(
      'flex min-w-0 flex-1 flex-col gap-4',
      mediaPosition === 'start' ? 'lg:order-2' : 'lg:order-1'
    )}
  >
    <slot />
  </div>
  <div
    class={cn(
      'w-full shrink-0 self-stretch',
      !bleedMedia && 'lg:w-[450px]',
      mediaPosition === 'start' ? 'lg:order-1' : 'lg:order-2'
    )}
    style={bleedStyle}
  >
    <slot name="media" />
  </div>
</div>

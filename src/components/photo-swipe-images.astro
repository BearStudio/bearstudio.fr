---
import { cn } from '@/lib/tailwind/utils';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div data-pswp-gallery class={cn(className)}>
  <slot />
</div>

<script>
  import { initImageLightbox } from '@/lib/photo-swipe';

  document
    .querySelectorAll<HTMLImageElement>('[data-pswp-gallery]')
    .forEach((wrapper) => {
      const img = wrapper.querySelector<HTMLImageElement>('img');
      if (img?.parentElement) {
        initImageLightbox(img, img.parentElement);
      }
    });
</script>

<style>
  [data-pswp-gallery] :global(img) {
    cursor: zoom-in;
  }
</style>

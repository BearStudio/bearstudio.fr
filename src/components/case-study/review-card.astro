---
interface Props {
  name: string;
  date: string;
  rating: number;
  store?: 'app-store' | 'google-play';
}

const { name, date, rating, store } = Astro.props;

const initials = name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .toUpperCase()
  .slice(0, 2);
---

<div class="not-prose bg-brand-800 flex flex-col gap-4 rounded-lg p-6">
  <div class="flex items-center gap-3">
    <div
      class="bg-brand-700 text-brand-200 flex size-10 shrink-0 items-center justify-center rounded-full text-sm font-semibold"
    >
      {initials}
    </div>
    <div class="flex flex-col">
      <span class="text-sm font-semibold text-white">{name}</span>
      <span class="text-brand-400 text-xs">{date}</span>
    </div>
  </div>

  <div class="flex gap-0.5">
    {
      Array.from({ length: 5 }).map((_, i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class:list={[
            'size-4',
            i < rating ? 'text-yellow-400' : 'text-brand-600',
          ]}
          viewBox="0 0 24 24"
          fill="currentColor"
          stroke="none"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      ))
    }
  </div>

  <p class="text-sm leading-relaxed text-white">
    <slot />
  </p>

  {
    store && (
      <div class="text-brand-400 mt-auto flex items-center gap-1.5 text-xs">
        {store === 'app-store' ? (
          <>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            <span>App Store</span>
          </>
        ) : (
          <>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.5 1.448a1 1 0 0 1 0 1.49l-2.5 1.448-2.533-2.533 2.533-2.853zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
            </svg>
            <span>Google Play</span>
          </>
        )}
      </div>
    )
  }
</div>

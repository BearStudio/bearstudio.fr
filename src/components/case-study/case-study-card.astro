---
import { cn } from '@/lib/tailwind/utils';

interface Props {
  class?: string | undefined;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    'not-prose w-full overflow-hidden rounded-lg bg-foreground text-background',
    className
  )}
>
  <div class="grid gap-6 p-6 md:grid-cols-2 md:gap-10">
    <!-- Left content -->
    <div class="flex flex-col gap-6 [&>p:empty]:hidden">
      <slot />
    </div>

    <!-- Right media -->
    <div class="flex items-center justify-center">
      <slot name="media" />
    </div>
  </div>
</div>
